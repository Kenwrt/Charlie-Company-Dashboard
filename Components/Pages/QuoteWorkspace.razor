@page "/quotes/{QuoteId:int}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrator,LocalOperator")]
@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using CharleyCompany.Dashboard.Web.Data
@using CharleyCompany.Dashboard.Web.Services
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject OperationAccessService OperationAccess
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Quote Workspace</PageTitle>
@if(quote is null){<h1>Quote not found</h1><p>This quote is not available to your assigned locations.</p>}
else{<section class="dashboard-shell"><div class="dashboard-header"><div><p class="eyebrow">@quote.LocalOperation.Name</p><h1>Quote CCV-Q-@quote.Id.ToString("D6")</h1><p class="dashboard-subtitle">@quote.CustomerName · @quote.WorkDescription</p></div><div class="dashboard-status"><span>@quote.Status</span><small>Version @version?.VersionNumber</small></div></div><p><a href="quotes">Back to quotes</a></p>
@if(message is not null){<div class="alert alert-info">@message</div>}
<section class="activity-panel"><h2>Integration references</h2><dl class="finance-definition-list"><div><dt>Housecall Pro quote</dt><dd>@(quote.HousecallProQuoteId??"Not assigned")</dd></div><div><dt>Housecall Pro job</dt><dd>@(quote.HousecallProJobId??"Not assigned")</dd></div><div><dt>CompanyCam project</dt><dd>@(quote.CompanyCamProjectId??"Not assigned")</dd></div></dl>@foreach(var job in quote.ProcessingJobs){<div class="activity-item"><div><strong>@job.JobType</strong><span>@job.Message</span></div><span>@job.Status</span></div>}</section>
@if(version is not null){<section class="activity-panel"><h2>Version @version.VersionNumber pricing</h2><div class="metric-grid"><article class="metric-card"><span>Subtotal</span><strong>@version.Subtotal.ToString("C")</strong></article><article class="metric-card"><span>Discount</span><strong>@version.DiscountAmount.ToString("C")</strong></article><article class="metric-card"><span>Tax</span><strong>@version.TaxAmount.ToString("C")</strong></article><article class="metric-card accent-revenue"><span>Customer total</span><strong>@version.Total.ToString("C")</strong></article></div>
@if(version.Status=="Draft"){<EditForm Model="lineInput" OnValidSubmit="AddLineAsync" FormName="quote-line"><DataAnnotationsValidator/><ValidationSummary class="text-danger"/><div class="row g-2 mt-3"><div class="col-md-3"><InputText class="form-control" @bind-Value="lineInput.Description" placeholder="Description"/></div><div class="col-md-1"><InputNumber class="form-control" @bind-Value="lineInput.Quantity"/></div><div class="col-md-1"><InputText class="form-control" @bind-Value="lineInput.Unit"/></div><div class="col-md-1"><InputNumber class="form-control" @bind-Value="lineInput.MaterialUnitCost" placeholder="Material"/></div><div class="col-md-1"><InputNumber class="form-control" @bind-Value="lineInput.LaborHours" placeholder="Hours"/></div><div class="col-md-1"><InputNumber class="form-control" @bind-Value="lineInput.LaborRate" placeholder="Rate"/></div><div class="col-md-1"><InputNumber class="form-control" @bind-Value="lineInput.EquipmentCost" placeholder="Equipment"/></div><div class="col-md-1"><InputNumber class="form-control" @bind-Value="lineInput.WastePercent" placeholder="Waste %"/></div><div class="col-md-1"><InputNumber class="form-control" @bind-Value="lineInput.MarkupPercent" placeholder="Markup %"/></div><div class="col-md-1"><button class="btn btn-primary">Add</button></div></div></EditForm>}
<div class="table-responsive mt-3"><table class="table"><thead><tr><th>Description</th><th>Qty</th><th>Estimated cost</th><th>Markup</th><th>Customer price</th></tr></thead><tbody>@foreach(var line in version.Lines.OrderBy(x=>x.SortOrder)){<tr><td>@line.Description<br/><small>@line.Source</small></td><td>@line.Quantity.ToString("N2") @line.Unit</td><td>@line.EstimatedCost.ToString("C")</td><td>@line.MarkupPercent.ToString("N1")%</td><td>@line.CustomerPrice.ToString("C")</td></tr>}</tbody></table></div>
@if(version.Status=="Draft"){<div class="d-flex gap-2"><button class="btn btn-outline-primary" @onclick="SubmitForReviewAsync">Submit for review</button><button class="btn btn-success" disabled="@(version.Lines.Count==0)" @onclick="ApproveAsync">Approve quote</button><button class="btn btn-outline-danger" @onclick="RejectAsync">Reject</button></div>}else if(version.Status=="Approved"){<button class="btn btn-outline-primary" @onclick="CreateRevisionAsync">Create revision</button><div class="alert alert-success mt-2">Approved version is locked. Customer delivery remains disabled.</div>}
</section>}
<details class="activity-panel"><summary><strong>Audit history</strong></summary><div class="activity-list mt-3">@foreach(var item in quote.AuditEvents.OrderByDescending(x=>x.OccurredAt)){<div class="activity-item"><div><strong>@item.PreviousStatus → @item.NewStatus</strong><span>@item.Explanation</span></div><time>@item.OccurredAt.ToLocalTime().ToString("MMM d, h:mm tt")</time></div>}</div></details></section>}

@code{
 [Parameter]public int QuoteId{get;set;} private QuoteCase? quote;private QuoteVersion? version;private QuoteLineInput lineInput=new();private string? message;
 protected override Task OnParametersSetAsync()=>ReloadAsync();
 private async Task ReloadAsync(){var allowed=(await OperationAccess.GetAccessibleOperationsAsync()).Select(x=>x.Id).ToList();quote=await DbContext.QuoteCases.AsNoTracking().AsSplitQuery().Include(x=>x.LocalOperation).Include(x=>x.Versions).ThenInclude(x=>x.Lines).Include(x=>x.AuditEvents).Include(x=>x.ProcessingJobs).SingleOrDefaultAsync(x=>x.Id==QuoteId&&allowed.Contains(x.LocalOperationId));version=quote?.Versions.OrderByDescending(x=>x.VersionNumber).FirstOrDefault();if(quote is not null){var rule=await DbContext.QuotePricingRules.AsNoTracking().SingleOrDefaultAsync(x=>x.LocalOperationId==quote.LocalOperationId);lineInput.LaborRate=rule?.DefaultLaborRate??75;lineInput.MarkupPercent=rule?.DefaultMarkupPercent??30;lineInput.WastePercent=rule?.DefaultWastePercent??10;}}
 private async Task AddLineAsync(){if(version is null||version.Status!="Draft")return;var cost=(lineInput.Quantity*lineInput.MaterialUnitCost*(1+lineInput.WastePercent/100m))+(lineInput.LaborHours*lineInput.LaborRate)+lineInput.EquipmentCost;var price=decimal.Round(cost*(1+lineInput.MarkupPercent/100m),2);DbContext.QuoteLines.Add(new QuoteLine{QuoteVersionId=version.Id,SortOrder=version.Lines.Count+1,Description=lineInput.Description.Trim(),Quantity=lineInput.Quantity,Unit=lineInput.Unit.Trim(),MaterialUnitCost=lineInput.MaterialUnitCost,LaborHours=lineInput.LaborHours,LaborRate=lineInput.LaborRate,EquipmentCost=lineInput.EquipmentCost,WastePercent=lineInput.WastePercent,MarkupPercent=lineInput.MarkupPercent,CustomerPrice=price});await DbContext.SaveChangesAsync();message="Quote line added using deterministic pricing inputs.";lineInput=new();await ReloadAsync();}
 private async Task TransitionAsync(string status,string explanation){if(quote is null)return;var tracked=await DbContext.QuoteCases.FindAsync(quote.Id);if(tracked is null)return;var previous=tracked.Status;tracked.Status=status;tracked.UpdatedAt=DateTimeOffset.UtcNow;var user=(await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;DbContext.QuoteAuditEvents.Add(new QuoteAuditEvent{QuoteCaseId=tracked.Id,PreviousStatus=previous,NewStatus=status,UserId=user.FindFirstValue(ClaimTypes.NameIdentifier),Explanation=explanation});await DbContext.SaveChangesAsync();await ReloadAsync();}
 private Task SubmitForReviewAsync()=>TransitionAsync(QuoteStatuses.OperatorReview,"Draft submitted for operator review.");
 private Task RejectAsync()=>TransitionAsync(QuoteStatuses.Rejected,"Quote rejected by operator.");
 private async Task ApproveAsync(){if(quote is null||version is null||version.Lines.Count==0)return;var tracked=await DbContext.QuoteVersions.FindAsync(version.Id);if(tracked is null||tracked.Status!="Draft")return;var user=(await AuthenticationStateProvider.GetAuthenticationStateAsync()).User;tracked.Status="Approved";tracked.ApprovedByUserId=user.FindFirstValue(ClaimTypes.NameIdentifier);tracked.ApprovedAt=DateTimeOffset.UtcNow;await DbContext.SaveChangesAsync();await TransitionAsync(QuoteStatuses.Approved,"Quote version approved. External update and customer email remain disabled.");}
 private async Task CreateRevisionAsync(){if(quote is null||version is null||version.Status!="Approved")return;var next=new QuoteVersion{QuoteCaseId=quote.Id,VersionNumber=version.VersionNumber+1,TaxRate=version.TaxRate,DiscountAmount=version.DiscountAmount,CustomerNotes=version.CustomerNotes};foreach(var line in version.Lines)next.Lines.Add(new QuoteLine{SortOrder=line.SortOrder,Description=line.Description,Quantity=line.Quantity,Unit=line.Unit,MaterialUnitCost=line.MaterialUnitCost,LaborHours=line.LaborHours,LaborRate=line.LaborRate,EquipmentCost=line.EquipmentCost,WastePercent=line.WastePercent,MarkupPercent=line.MarkupPercent,CustomerPrice=line.CustomerPrice,Source="Revision"});DbContext.Add(next);await DbContext.SaveChangesAsync();await TransitionAsync(QuoteStatuses.RevisionRequested,"A new editable quote version was created.");}
 private sealed class QuoteLineInput{[Required]public string Description{get;set;}="";[Range(.0001,double.MaxValue)]public decimal Quantity{get;set;}=1;[Required]public string Unit{get;set;}="Each";[Range(0,double.MaxValue)]public decimal MaterialUnitCost{get;set;}[Range(0,double.MaxValue)]public decimal LaborHours{get;set;}[Range(0,double.MaxValue)]public decimal LaborRate{get;set;}=75;[Range(0,double.MaxValue)]public decimal EquipmentCost{get;set;}[Range(0,100)]public decimal WastePercent{get;set;}=10;[Range(0,1000)]public decimal MarkupPercent{get;set;}=30;}
}
